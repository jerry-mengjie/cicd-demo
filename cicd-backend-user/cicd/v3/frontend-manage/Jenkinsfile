pipeline {
  agent any

  environment {
    APP_NAME      = 'frontend-manage'
    REGISTRY      = 'localhost:8082'
    IMAGE_TAG     = 'latest'
    IMAGE_NAME    = "${APP_NAME}:${IMAGE_TAG}"
    IMAGE_FULL    = "${REGISTRY}/${IMAGE_NAME}"
  }

  stages {
    /* ========== 1. 获取代码 ========== */
    stage('获取代码') {
      steps {
        checkout([
          $class: 'GitSCM',
          branches: [[name: '*/main']],
          userRemoteConfigs: [[
            url: 'git@github.com:jerry-mengjie/cicd-demo.git'
          ]]
        ])
      }
    }

    /* ========== 2. 构建代码 ========== */
    stage('构建代码') {
      steps {
        script {
          sh """
            cd cicd-frontend-manage &&
            export PATH=/Users/jerry/.nvm/versions/node/v20.19.6/bin:/Users/jerry/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH &&
            pnpm install &&
            pnpm run build
          """
        }
      }
    }

    /* ========== 3. 构建镜像 ========== */
    stage('构建镜像') {
      steps {
        script {
          sh "docker build -t ${IMAGE_NAME} -f cicd-frontend-manage/Dockerfile ."
        }
      }
    }

    /* ========== 4. 推送仓库 ========== */
    stage('推送仓库') {
      steps {
        script {
          sh "docker tag ${IMAGE_NAME} ${IMAGE_FULL}"
          sh "docker push ${IMAGE_FULL}"
          sh "docker rmi ${IMAGE_NAME} || true"
          sh "docker rmi ${IMAGE_FULL} || true"
        }
      }
    }

    /* ========== 5. 部署容器 ========== */
    stage('部署容器') {
      steps {
        script {
          sh 'bash /opt/deploy/test/ht-sgb/deploy.sh'
        }
      }
    }
  }
}
